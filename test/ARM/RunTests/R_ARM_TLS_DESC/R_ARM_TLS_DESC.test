REQUIRES: run_test
#---R_ARM_TLS_DESC.test----------------- Executable------------------#
#BEGIN_COMMENT
# Test the ARM R_ARM_TLS_DESC relocation.
# R_ARM_TLS_DESC is a TLS descriptor relocation that provides an
# efficient mechanism for accessing thread-local storage by referencing
# a function pointer and argument pair in the GOT, allowing the runtime
# to resolve TLS offsets.
# Covers: static
#END_COMMENT
#START_TEST

#RUN: %run_cc -nostdlib -c -o %t.startup.o %p/Inputs/startup.s
#RUN: %run_cc -nostdlib -c -o %t.main.o %p/Inputs/main.s
#RUN: %readelf -r %t.main.o | %filecheck %s -check-prefix MAIN-RELOCS
# Static - link is expected to fail because R_ARM_TLS_DESC is unsupported
#RUN: %not %run_cc -static -nostartfiles -o %t.static.out %t.startup.o %t.main.o 2>&1 | %filecheck %s -check-prefix LINK-ERROR

#MAIN-RELOCS: {{.*}} R_ARM_TLS_DESC {{.*}} tls_var
#LINK-ERROR: Unsupported relocation found during relocation scan `R_ARM_TLS_DESC'

#END_TEST
