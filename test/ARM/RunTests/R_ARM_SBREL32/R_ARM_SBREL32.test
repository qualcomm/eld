REQUIRES: run_test
#---R_ARM_SBREL32.test------------------ Executable------------------#
#BEGIN_COMMENT
# Test the ARM R_ARM_SBREL32 relocation.
# R_ARM_SBREL32 is a segment-base-relative relocation that encodes the
# offset from the base address of the PT_LOAD segment containing the
# target symbol to the target symbol itself, enabling position-independent
# data addressing relative to a known segment base.
# Covers: static
#END_COMMENT
#START_TEST

#RUN: %run_cc -nostdlib -c -o %t.startup.o %p/Inputs/startup.s
#RUN: %run_cc -nostdlib -c -o %t.main.o %p/Inputs/main.s
#RUN: %readelf -r %t.main.o | %filecheck %s -check-prefix MAIN-RELOCS
# Static
#RUN: %run_cc -static -nostartfiles -o %t.static.out %t.startup.o %t.main.o
#RUN: %objdump -d %t.static.out | %filecheck %s -check-prefix STATIC
#RUN: %run %t.static.out

#MAIN-RELOCS: {{.*}} R_ARM_SBREL32 {{.*}} target
#STATIC: ldr r0, [pc, {{.*}}] @ 0x[[SLOT_ADDR:[0-9a-f]+]]
#STATIC: ldr r3, [pc, {{.*}}] @ 0x[[TGT_ADDR:[0-9a-f]+]]
#STATIC: [[SLOT_ADDR]]: {{.*}} .word
#STATIC: [[TGT_ADDR]]: {{.*}} .word

#END_TEST
