REQUIRES: run_test
#---R_ARM_THM_XPC22.test---------------- Executable------------------#
#BEGIN_COMMENT
# Test the ARM R_ARM_THM_XPC22 relocation.
# R_ARM_THM_XPC22 is a PC-relative relocation for Thumb inter-working
# branch instructions that encodes a 22-bit signed offset to a target
# in a different execution state (Thumb to ARM or vice versa).
# Covers: static
#END_COMMENT
#START_TEST

#RUN: %run_cc -nostdlib -c -o %t.startup.o %p/Inputs/startup.s
#RUN: %run_cc -nostdlib -c -o %t.main.o %p/Inputs/main.s
#RUN: %readelf -r %t.main.o | %filecheck %s -check-prefix MAIN-RELOCS
# Static - link is expected to fail because R_ARM_THM_XPC22 is unsupported
#RUN: %not %run_cc -static -nostartfiles -o %t.static.out %t.startup.o %t.main.o 2>&1 | %filecheck %s -check-prefix LINK-ERROR

#MAIN-RELOCS: {{.*}} R_ARM_THM_XPC22 {{.*}} target
#LINK-ERROR: Unsupported relocation found during relocation scan `R_ARM_THM_XPC22'

#END_TEST
