REQUIRES: riscv32 || riscv64
#----------TP_RELAX.test----------------- Executable------------------#
#BEGIN_COMMENT
# Test thread-pointer relaxation for local-exec TLS accesses.
#END_COMMENT
#START_TEST

RUN: %clang %clangopts -c %p/Inputs/tp_relax.s -o %t.o

## Check --no-relax and --no-relax-tp both suppress the relaxation.
RUN: %link %linkopts -static --no-relax --verbose -MapStyle txt -Map %t.norelax.map \
RUN:   %t.o -o %t.norelax.out 2>&1 | %filecheck %s --check-prefix=NO-RELAX-VERBOSE
RUN: %link %linkopts -static --no-relax-tp --verbose -MapStyle txt -Map %t.norelaxtp.map \
RUN:   %t.o -o %t.norelaxtp.out 2>&1 | %filecheck %s --check-prefix=NO-RELAX-VERBOSE
RUN: %objdump --no-print-imm-hex -M no-aliases -d %t.norelax.out | %filecheck %s --check-prefix=NO-RELAX-DUMP
RUN: %objdump --no-print-imm-hex -M no-aliases -d %t.norelaxtp.out | %filecheck %s --check-prefix=NO-RELAX-DUMP
RUN: %filecheck %s --input-file=%t.norelax.map --check-prefix=NO-RELAX-MAP
RUN: %filecheck %s --input-file=%t.norelaxtp.map --check-prefix=NO-RELAX-MAP

## Check relaxable cases.
RUN: %link %linkopts -static --verbose -MapStyle txt -Map %t.map \
RUN: %t.o -o %t.out 2>&1 | %filecheck %s --check-prefix=RELAX-VERBOSE
RUN: %objdump --no-print-imm-hex -M no-aliases -d %t.out | %filecheck %s --check-prefix=RELAX-DUMP
RUN: %filecheck %s --input-file=%t.map --check-prefix=RELAX-MAP

NO-RELAX-VERBOSE: RISCV_TPREL : Cannot relax 4 bytes for symbol 'sym_in'
NO-RELAX-VERBOSE-NEXT: RISCV_TPREL : Cannot relax 4 bytes for symbol 'sym_in'
