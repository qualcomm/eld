#---SysrootNamespecInput.test--------------------------- Executable -----------------#
#BEGIN_COMMENT
# This test checks that namespec libraries (e.g. INPUT(-lfoo)) are found in
# standard directories under the sysroot such as /lib64.
#END_COMMENT
#START_TEST
RUN: rm -rf %t.sysroot
RUN: mkdir -p %t.sysroot/lib64
RUN: %clang %clangopts -o %t1.o %p/Inputs/1.c -c
RUN: %clang %clangopts -o %t.lib1.o %p/Inputs/lib1.c -c
RUN: %ar cr %aropts %t.sysroot/lib64/lib1.a %t.lib1.o
RUN: %link %linkopts --sysroot=%t.sysroot -T %p/Inputs/script2.t %t1.o -o %t1.out
#END_TEST
