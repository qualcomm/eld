#---EntryCmdInSectionsCmdlineOverride.test--------- Executable,LS--------------#
#BEGIN_COMMENT
# This test checks that an entry symbol specified on the command line (-e)
# takes precedence over an ENTRY command nested inside the SECTIONS command.
#END_COMMENT
#START_TEST
RUN: %clang %clangopts -c %p/Inputs/1.c -o %t1.o -ffunction-sections
RUN: %link %linkopts %t1.o -T %p/Inputs/script.t -o %t2.out -e 0
RUN: %readelf -h %t2.out | %filecheck %s
#CHECK: Entry point address: 0x0
#END_TEST
