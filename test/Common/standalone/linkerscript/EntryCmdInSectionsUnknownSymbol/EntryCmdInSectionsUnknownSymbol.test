#---EntryCmdInSectionsUnknownSymbol.test------------ Executable,LS-------------#
#BEGIN_COMMENT
# This test checks that an ENTRY command nested inside the SECTIONS command
# with an unresolved entry symbol emits the same warning and defaults to
# address 0, matching the behavior of a top-level ENTRY command.
#END_COMMENT
#START_TEST
RUN: %clang %clangopts -c %p/Inputs/1.c -o %t1.o
RUN: %link %emulation %linkopts %t1.o -T %p/Inputs/script.t --verbose -o %t2.out 2>&1 | %filecheck %s
RUN: %readelf -h %t2.out | %filecheck %s --check-prefix=ENTRY
#CHECK: Verbose: Entry symbol unknown_symbol
#CHECK: Warning: unknown_symbol Entry symbol not found, defaulting to 0
#ENTRY: Entry point address: 0x0
#END_TEST
