REQUIRES: symbol_versioning
#---DuplicateDefault.test-------------------------------------------------#
# Two strong default-version `bar@@V1` symbols in different objects must
# multi-def on the canonical bar@V1 NamePool key.
#START_TEST
RUN: %clang %clangopts -o %t.a.o %p/Inputs/strong_default.c -c -fPIC
RUN: %clang %clangopts -o %t.b.o %p/Inputs/strong_default.c -c -fPIC
RUN: not %link %linkopts -o %t.lib.so %t.a.o %t.b.o -shared --version-script %p/Inputs/vs_v1.t 2>&1 | %filecheck %s
#END_TEST

CHECK: multiple definition of symbol
