REQUIRES: symbol_versioning
#---WeakStrongDefault_BindingSwapped.test---------------------------------#
# R2.4 regression: same as WeakStrongDefault but with the strong/weak
# inputs in the opposite link order. Confirms ordering independence of
# the sameDefinition() guard.
#START_TEST
RUN: %clang %clangopts -o %t.a.o %p/Inputs/strong_default.c -c -fPIC
RUN: %clang %clangopts -o %t.b.o %p/Inputs/weak_default.c -c -fPIC
RUN: %link %linkopts -o %t.lib.so %t.a.o %t.b.o -shared --version-script %p/Inputs/vs_v1.t
RUN: %readelf --dyn-syms --version-info %t.lib.so | %filecheck %s
#END_TEST

CHECK-DAG: bar@@V1
CHECK-NOT: : bar{{$}}
