REQUIRES: symbol_versioning
#---01_StrongDefault_StrongNonDefault_MultipleDef.test--------------------#
#BEGIN_COMMENT
# Rule 1 from problem.txt: strong bar@@V1 (a.o) + strong bar@V1 (b.o)
# must be a multiple-definition error. Resolver fires the diagnostic on
# the canonical bar@V1 NamePool key.
#END_COMMENT
#START_TEST
RUN: %clang %clangopts -o %t.a.o %p/Inputs/strong_default.c -c -fPIC
RUN: %clang %clangopts -o %t.b.o %p/Inputs/strong_nondefault.c -c -fPIC
RUN: not %link %linkopts -o %t.lib.so %t.a.o %t.b.o -shared --version-script %p/Inputs/vs_v1.t 2>&1 | %filecheck %s
#END_TEST

CHECK: multiple definition of symbol `bar@V1'
