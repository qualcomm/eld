REQUIRES: symbol_versioning
#---03_WeakDefault_StrongNonDefault.test----------------------------------#
#BEGIN_COMMENT
# Rule 3: weak bar@@V1 (a.o) + strong bar@V1 (b.o). Strong takes the
# canonical slot; default-version identity transfers from a -> b.
# Output: bar@@V1 backed by b.o.
#END_COMMENT
#START_TEST
RUN: %clang %clangopts -o %t.a.o %p/Inputs/weak_default.c -c -fPIC
RUN: %clang %clangopts -o %t.b.o %p/Inputs/strong_nondefault.c -c -fPIC
RUN: %link %linkopts -o %t.lib.so %t.a.o %t.b.o -shared --version-script %p/Inputs/vs_v1.t
RUN: %readelf --dyn-syms --version-info %t.lib.so | %filecheck %s
#END_TEST

CHECK-DAG: bar@@V1
CHECK-NOT: : bar{{$}}
CHECK-NOT: bar@V1{{$}}
