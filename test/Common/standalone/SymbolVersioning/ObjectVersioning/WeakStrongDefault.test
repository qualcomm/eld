REQUIRES: symbol_versioning
#---WeakStrongDefault.test------------------------------------------------#
# R2.4 regression: weak `bar@@V1` (a.o) + strong `bar@@V1` (b.o). Strong
# overrides weak on both pair slots. The sameDefinition() guard in
# branch (4) of normalizeSymbols must NOT misdiagnose this as rule-5
# multi-def.
#START_TEST
RUN: %clang %clangopts -o %t.a.o %p/Inputs/weak_default.c -c -fPIC
RUN: %clang %clangopts -o %t.b.o %p/Inputs/strong_default.c -c -fPIC
RUN: %link %linkopts -o %t.lib.so %t.a.o %t.b.o -shared --version-script %p/Inputs/vs_v1.t
RUN: %readelf --dyn-syms --version-info %t.lib.so | %filecheck %s
#END_TEST

CHECK-DAG: bar@@V1
CHECK-NOT: : bar{{$}}
