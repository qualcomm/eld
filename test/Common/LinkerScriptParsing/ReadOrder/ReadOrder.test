#---ReadOrder.test--------------------- Executable---------------------#
#BEGIN_COMMENT
# This test verifies that -T scripts parsed during input activation do not make
# assignments in earlier linker-script inputs appear after SECTIONS.
#END_COMMENT
#START_TEST

RUN: %clang %clangopts -c %p/Inputs/1.c -o %t.o
RUN: %link %linkopts -r %t.o %p/Inputs/another_script.t -T %p/Inputs/script.t -o %t.out
RUN: %readelf -s %t.out | %filecheck %s

#END_TEST

CHECK: {{0+}}200     0 NOTYPE  GLOBAL DEFAULT  ABS u
